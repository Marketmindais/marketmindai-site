---
import Base from '../../layouts/Base.astro';
---
<Base
  title="AI Marketing Tools"
  description="Free and premium AI tools for keyword research, content briefs, SEO audits, and competitor analysis."
>
  <div class="max-w-5xl mx-auto px-6 py-16">
    <div class="text-center mb-14">
      <h1 class="text-4xl font-extrabold mb-3">AI Marketing Tools</h1>
      <p class="text-gray-500 max-w-xl mx-auto">Free tools to level up your marketing — powered by the same AI that runs MarketMindAI Pro.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border rounded-xl p-6 hover:shadow-md transition">
        <span class="inline-block bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded mb-3">FREE</span>
        <h2 class="font-bold text-lg mb-2">Keyword Cluster Tool</h2>
        <p class="text-gray-500 text-sm mb-4">Paste keywords, get semantic clusters and topical maps instantly.</p>
        <a href="/pricing" class="text-indigo-600 text-sm font-semibold hover:underline">Try free &rarr;</a>
      </div>

      <div class="border rounded-xl p-6 hover:shadow-md transition">
        <span class="inline-block bg-indigo-100 text-indigo-700 text-xs font-bold px-2 py-1 rounded mb-3">PRO</span>
        <h2 class="font-bold text-lg mb-2">Content Brief Generator</h2>
        <p class="text-gray-500 text-sm mb-4">Full NLP-based briefs with headings, entities, and word count targets.</p>
        <a href="/pricing" class="text-indigo-600 text-sm font-semibold hover:underline">Upgrade to Pro &rarr;</a>
      </div>

      <div class="border rounded-xl p-6 hover:shadow-md transition">
        <span class="inline-block bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded mb-3">FREE</span>
        <h2 class="font-bold text-lg mb-2">Meta Tag Analyzer</h2>
        <p class="text-gray-500 text-sm mb-4">Check title tags, descriptions, and canonical tags for any URL.</p>
        <a href="/pricing" class="text-indigo-600 text-sm font-semibold hover:underline">Try free &rarr;</a>
      </div>

      <div class="border rounded-xl p-6 hover:shadow-md transition">
        <span class="inline-block bg-indigo-100 text-indigo-700 text-xs font-bold px-2 py-1 rounded mb-3">PRO</span>
        <h2 class="font-bold text-lg mb-2">Competitor Gap Finder</h2>
        <p class="text-gray-500 text-sm mb-4">See which keywords your rivals rank for that you don't — with traffic estimates.</p>
        <a href="/pricing" class="text-indigo-600 text-sm font-semibold hover:underline">Upgrade to Pro &rarr;</a>
      </div>
    </div>
  </div>
</Base>
