---
import Base from '../layouts/Base.astro';
---
<Base
  title="AI-Powered Marketing Intelligence"
  description="MarketMindAI gives marketers real-time AI insights, keyword research, content briefs, and competitor analysis. Start free."
>
  <section class="max-w-4xl mx-auto px-6 py-20 text-center">
    <p class="text-indigo-600 font-semibold text-sm uppercase tracking-widest mb-4">AI Marketing Intelligence</p>
    <h1 class="text-5xl font-extrabold leading-tight mb-6">Turn Data Into Revenue<br/>With AI Marketing Tools</h1>
    <p class="text-xl text-gray-500 mb-10 max-w-2xl mx-auto">
      MarketMindAI automates keyword research, generates SEO-optimised content briefs, and surfaces competitor gaps — so you can outrank without the guesswork.
    </p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a href="/pricing" class="bg-indigo-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-indigo-700 transition">Start Free Trial</a>
      <a href="/tools" class="border border-gray-300 px-8 py-3 rounded-lg font-semibold hover:border-indigo-400 transition">See Tools</a>
    </div>
  </section>

  <section class="bg-gray-50 py-20">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-14">Everything You Need to Win Search</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white p-6 rounded-xl shadow-sm border">
          <div class="text-indigo-600 text-2xl mb-3">&#128270;</div>
          <h3 class="font-bold text-lg mb-2">Keyword Intelligence</h3>
          <p class="text-gray-500 text-sm">Discover high-intent keywords your competitors are missing. AI clusters topics for maximum topical authority.</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border">
          <div class="text-indigo-600 text-2xl mb-3">&#9997;</div>
          <h3 class="font-bold text-lg mb-2">Content Briefs</h3>
          <p class="text-gray-500 text-sm">Generate SEO-ready briefs in seconds. Includes headings, word count, internal links, and NLP entities.</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border">
          <div class="text-indigo-600 text-2xl mb-3">&#128202;</div>
          <h3 class="font-bold text-lg mb-2">Competitor Gap Analysis</h3>
          <p class="text-gray-500 text-sm">See exactly where rivals rank and you don't. Prioritise the pages with the highest ROI potential.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-3xl font-bold mb-6">From the Blog</h2>
    <p class="text-gray-500 mb-8">Actionable guides on AI marketing, SEO, and growth.</p>
    <a href="/blog" class="text-indigo-600 font-semibold hover:underline">Read all articles &rarr;</a>
  </section>
</Base>
