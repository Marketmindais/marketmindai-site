---
import Base from '../../layouts/Base.astro';

const rawPosts = import.meta.glob('./*.md', { eager: true });
const posts = Object.values(rawPosts) as any[];
const sorted = posts.sort((a, b) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);

function fmtDate(d: string | Date) {
  return new Date(d).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
}

// Safely normalise tags from frontmatter — handles arrays, strings, and mangled formats
function normalizeTags(raw: any): string[] {
  if (!raw) return [];
  if (Array.isArray(raw)) return raw.map(String);
  const s = String(raw).replace(/^\[|\]$/g, "").replace(/['"]/g, "");
  return s.split(",").map(t => t.trim()).filter(Boolean);
}

// Map product names to gradient pairs for visual variety
const gradients: Record<string, string> = {
  "Vapi AI":       "from-violet-500 to-indigo-600",
  "Relevance AI":  "from-emerald-500 to-teal-600",
  "default":       "from-indigo-500 to-purple-600",
};
---
<Base
  title="Blog"
  description="In-depth AI tool reviews, comparisons, and marketing guides from the MarketMindAI team."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-indigo-50 via-white to-violet-50 pt-16 pb-14 border-b border-gray-100">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-xs font-semibold text-indigo-600 uppercase tracking-widest mb-3">MarketMindAI Blog</p>
      <h1 class="text-4xl font-extrabold text-gray-900 mb-4">AI Tools, Reviews & Marketing Guides</h1>
      <p class="text-gray-500 text-lg max-w-xl mx-auto">
        Honest reviews and step-by-step guides on the tools that actually move the needle.
      </p>
    </div>
  </section>

  <!-- Articles -->
  <section class="max-w-6xl mx-auto px-6 py-16">

    {sorted.length === 0 ? (
      <p class="text-center text-gray-400 py-20 text-lg">No posts yet — check back soon.</p>
    ) : (
      <>
        <!-- Featured post (first one) -->
        {sorted[0] && (() => {
          const post = sorted[0];
          const product = post.frontmatter.affiliate_name || normalizeTags(post.frontmatter.tags)[0] || "default";
          const grad = gradients[product] ?? gradients["default"];
          return (
            <a href={post.url} class="group block mb-14">
              <div class="rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-md transition-shadow flex flex-col md:flex-row">
                <!-- Color block -->
                <div class={`bg-gradient-to-br ${grad} md:w-72 h-48 md:h-auto flex items-center justify-center p-8 shrink-0`}>
                  <span class="text-white font-bold text-xl text-center leading-snug opacity-90">
                    {post.frontmatter.affiliate_name || "AI Tools"}
                  </span>
                </div>
                <!-- Content -->
                <div class="p-8 flex flex-col justify-between">
                  <div>
                    <div class="flex flex-wrap gap-2 mb-3">
                      {normalizeTags(post.frontmatter.tags).map((t: string) => (
                        <span class="text-xs bg-indigo-100 text-indigo-700 font-medium px-2.5 py-1 rounded-full">{t}</span>
                      ))}
                    </div>
                    <h2 class="text-2xl font-extrabold text-gray-900 mb-3 group-hover:text-indigo-600 transition-colors leading-snug">
                      {post.frontmatter.title}
                    </h2>
                    <p class="text-gray-500 leading-relaxed line-clamp-3">{post.frontmatter.description}</p>
                  </div>
                  <div class="flex items-center justify-between mt-6">
                    <time class="text-xs text-gray-400">{fmtDate(post.frontmatter.date)}</time>
                    <span class="text-sm font-semibold text-indigo-600 group-hover:underline">Read review &rarr;</span>
                  </div>
                </div>
              </div>
            </a>
          );
        })()}

        <!-- Rest of posts grid -->
        {sorted.length > 1 && (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {sorted.slice(1).map(post => {
              const product = post.frontmatter.affiliate_name || normalizeTags(post.frontmatter.tags)[0] || "default";
              const grad = gradients[product] ?? gradients["default"];
              return (
                <a href={post.url} class="group block rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow overflow-hidden">
                  <!-- Color header -->
                  <div class={`bg-gradient-to-r ${grad} h-32 flex items-center justify-center px-6`}>
                    <span class="text-white font-bold text-base text-center leading-snug opacity-90">
                      {post.frontmatter.affiliate_name || "AI Tools"}
                    </span>
                  </div>
                  <!-- Body -->
                  <div class="p-6">
                    <div class="flex flex-wrap gap-1.5 mb-3">
                      {normalizeTags(post.frontmatter.tags).slice(0, 2).map((t: string) => (
                        <span class="text-xs bg-gray-100 text-gray-600 font-medium px-2 py-0.5 rounded-full">{t}</span>
                      ))}
                    </div>
                    <h2 class="font-bold text-gray-900 text-base mb-2 group-hover:text-indigo-600 transition-colors leading-snug line-clamp-2">
                      {post.frontmatter.title}
                    </h2>
                    <p class="text-sm text-gray-500 line-clamp-2 leading-relaxed mb-4">{post.frontmatter.description}</p>
                    <div class="flex items-center justify-between">
                      <time class="text-xs text-gray-400">{fmtDate(post.frontmatter.date)}</time>
                      <span class="text-xs font-semibold text-indigo-600 group-hover:underline">Read &rarr;</span>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </>
    )}
  </section>
</Base>
